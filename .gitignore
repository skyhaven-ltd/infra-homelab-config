# Legacy compose appdata (never tracked)
appdata/

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl.backup
crash.log

# Ansible — inventory is Terraform-generated
ansible/inventory/hosts.yml

# Secrets / creds — never in Git
*.key
*-kubeconfig

# docs/ is ignored by the developer-machine global gitignore; keep it tracked here
!docs/
!docs/**
