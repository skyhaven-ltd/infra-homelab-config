APP_PORT=8080
DATABASE_URL=sqlite:////data/bookbuddy.db
UPLOAD_DIR=/data/uploads
# Direct API generation (optional). Leave empty to queue generation jobs for
# the host-side worker instead (subscription billing, no API costs).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Shared secret for the worker endpoints. Use a long random value.
WORKER_TOKEN=change-me-worker-token
# Worker-side only: where the worker script finds the app.
APP_BASE_URL=http://127.0.0.1:8080
