# Copy to .env and fill in. docker-compose loads this automatically.

# ntfy — use http://ntfy:80 when running the bundled ntfy container,
# or https://ntfy.sh for the public service.
NTFY_SERVER=http://ntfy:80
NTFY_TOPIC=stock-alerts-change-me
NTFY_TOKEN=

# Telegram (optional; set notifiers.telegram.enabled: true in config.yaml)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
